rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActive() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.active == true
        && (!currentUser().data.keys().hasAny(['accessLocked'])
          || currentUser().data.accessLocked != true);
    }

    function isAdmin() {
      return isActive()
        && currentUser().data.role == 'admin';
    }

    function validUserRole(role) {
      return role in ['admin', 'solicitante'];
    }

    function validType(type) {
      return type in ['programacao', 'cancelamento', 'tef_elgin'];
    }

    function validPriority(priority) {
      return priority in ['urgente', 'alta', 'normal', 'baixa'];
    }

    function validStatus(status) {
      return status in ['nova', 'analise', 'aguardando', 'bloqueio', 'concluida'];
    }

    function validCancellationCrmData(data) {
      return data.type != 'cancelamento'
        || (data.keys().hasAll(['cancellationCrmStatus'])
          && data.cancellationCrmStatus is map);
    }

    function emptyCancellationCrmOnCreate(data) {
      return data.type != 'cancelamento'
        || (validCancellationCrmData(data)
          && data.cancellationCrmStatus.size() == 0);
    }

    function cancellationCrmUnchangedByRequester() {
      let oldHas = resource.data.keys().hasAny(['cancellationCrmStatus']);
      let newHas = request.resource.data.keys().hasAny(['cancellationCrmStatus']);
      return (!oldHas
          && (!newHas
            || (request.resource.data.cancellationCrmStatus is map
              && request.resource.data.cancellationCrmStatus.size() == 0)))
        || (oldHas
          && newHas
          && request.resource.data.cancellationCrmStatus == resource.data.cancellationCrmStatus);
    }

    function cancellationListCanChangeByRequester() {
      let hasTracking = resource.data.keys().hasAny(['cancellationCrmStatus']);
      return resource.data.type != 'cancelamento'
        || !hasTracking
        || resource.data.cancellationCrmStatus.size() == 0
        || request.resource.data.cancellationItems == resource.data.cancellationItems;
    }

    function validProgrammingData(data) {
      return data.type != 'programacao'
        || (data.clientCode is string
          && data.clientCode.size() == 18);
    }

    function validTefData(data) {
      return data.type != 'tef_elgin'
        || (data.tefCnpj is string
          && data.tefCnpj.size() >= 14
          && data.tefCnpj.size() <= 18
          && data.tefOperatingSystem is string
          && data.tefOperatingSystem.size() > 0
          && data.tefOperatingSystem.size() <= 120
          && data.tefRam is string
          && data.tefRam.size() > 0
          && data.tefRam.size() <= 40
          && data.tefSystemUsed is string
          && data.tefSystemUsed.size() > 0
          && data.tefSystemUsed.size() <= 80
          && data.tefEstablishmentNumber is string
          && data.tefEstablishmentNumber.size() > 0
          && data.tefEstablishmentNumber.size() <= 120
          && data.tefPinpadLogicalNumber is string
          && data.tefPinpadLogicalNumber.size() > 0
          && data.tefPinpadLogicalNumber.size() <= 120
          && data.tefPinpadModel is string
          && data.tefPinpadModel.size() > 0
          && data.tefPinpadModel.size() <= 120
          && data.tefAcquirer is string
          && data.tefAcquirer.size() > 0
          && data.tefAcquirer.size() <= 120
          && data.tefOwnerName is string
          && data.tefOwnerName.size() > 0
          && data.tefOwnerName.size() <= 160
          && data.tefOwnerCpf is string
          && data.tefOwnerCpf.size() >= 11
          && data.tefOwnerCpf.size() <= 14
          && data.tefContactPhone is string
          && data.tefContactPhone.size() >= 10
          && data.tefContactPhone.size() <= 15
          && data.tefContactEmail is string
          && data.tefContactEmail.size() > 3
          && data.tefContactEmail.size() <= 160
          && data.tefAgreedValue is string
          && data.tefAgreedValue.size() > 0
          && data.tefAgreedValue.size() <= 120);
    }

    function validRequestData(data) {
      return validType(data.type)
        && validPriority(data.priority)
        && validStatus(data.status)
        && data.clientName is string
        && data.clientName.size() > 0
        && data.clientName.size() <= 120
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 140
        && data.description is string
        && data.description.size() > 0
        && data.description.size() <= 3000
        && validProgrammingData(data)
        && validTefData(data)
        && validCancellationCrmData(data);
    }

    function validAttachmentData(data) {
      return data.requestId is string
        && data.requestId.size() > 0
        && data.ownerUid is string
        && data.ownerUid.size() > 0
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 180
        && data.contentType in ['image/jpeg', 'image/png', 'text/plain']
        && data.size is int
        && data.size > 0
        && data.size <= 716800
        && data.data is bytes
        && data.data.size() <= 716800;
    }

    function validInviteData(data) {
      return data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 160
        && validUserRole(data.role)
        && data.status == 'pending'
        && data.createdByUid == request.auth.uid
        && data.createdAt == request.time
        && data.expiresAt is timestamp
        && data.expiresAt > request.time;
    }

    function validInvitedUser(userId, data) {
      let invite = get(/databases/$(database)/documents/userInvites/$(data.inviteToken));
      return signedIn()
        && request.auth.uid == userId
        && data.inviteToken is string
        && data.inviteToken.size() >= 32
        && invite.data.status == 'pending'
        && invite.data.expiresAt > request.time
        && invite.data.email == request.auth.token.email
        && data.email == invite.data.email
        && data.name == invite.data.name
        && data.role == invite.data.role
        && data.active == true
        && data.createdAt == request.time;
    }

    function isRequestParticipant(data) {
      return isActive()
        && (data.requesterUid == request.auth.uid
          || (data.keys().hasAny(['assigneeUid'])
            && data.assigneeUid == request.auth.uid));
    }

    function canViewProgramming(data) {
      return isActive()
        && currentUser().data.role == 'solicitante'
        && data.type == 'programacao';
    }

    function canReadActiveRequest(requestId) {
      let path = /databases/$(database)/documents/requests/$(requestId);
      return exists(path)
        && (isAdmin()
          || isRequestParticipant(get(path).data)
          || canViewProgramming(get(path).data));
    }

    function canParticipateActiveRequest(requestId) {
      let path = /databases/$(database)/documents/requests/$(requestId);
      return exists(path)
        && (isAdmin() || isRequestParticipant(get(path).data));
    }

    function canReadArchivedRequest(requestId) {
      return isAdmin()
        && exists(/databases/$(database)/documents/archivedRequests/$(requestId));
    }

    function validCommentData(data) {
      return data.requestId is string
        && data.requestId.size() > 0
        && data.requestTitle is string
        && data.requestTitle.size() <= 140
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000
        && data.authorUid == request.auth.uid
        && data.authorName is string
        && data.authorName.size() > 0
        && data.authorName.size() <= 160
        && data.authorEmail == request.auth.token.email
        && data.mentionUid is string
        && data.mentionName is string
        && (data.mentionUid == ''
          || (isAdmin()
            && exists(/databases/$(database)/documents/users/$(data.mentionUid))
            && get(/databases/$(database)/documents/users/$(data.mentionUid)).data.active == true))
        && data.createdAt == request.time;
    }

    function commentCountIncremented() {
      let oldHasCount = resource.data.keys().hasAny(['commentCount']);
      return request.resource.data.commentCount is int
        && ((oldHasCount && request.resource.data.commentCount == resource.data.commentCount + 1)
          || (!oldHasCount && request.resource.data.commentCount == 1));
    }

    function validNotificationData(data) {
      let requestPath = /databases/$(database)/documents/requests/$(data.requestId);
      return isAdmin()
        && data.targetUid is string
        && data.targetUid.size() > 0
        && exists(/databases/$(database)/documents/users/$(data.targetUid))
        && get(/databases/$(database)/documents/users/$(data.targetUid)).data.active == true
        && data.createdByUid == request.auth.uid
        && data.createdByName is string
        && data.requestId is string
        && data.requestId.size() > 0
        && exists(requestPath)
        && (get(requestPath).data.requesterUid == data.targetUid
          || (get(requestPath).data.keys().hasAny(['assigneeUid'])
            && get(requestPath).data.assigneeUid == data.targetUid))
        && data.requestTitle is string
        && data.requestTitle.size() <= 140
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 300
        && data.type in ['mention', 'assignment', 'status', 'blocked', 'paused_24h', 'system']
        && data.read == false
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      allow create: if isAdmin() || validInvitedUser(userId, request.resource.data);

      allow update: if (isAdmin()
        && request.resource.data.email == resource.data.email
        && validUserRole(request.resource.data.role)
        && request.resource.data.active is bool
        && (request.auth.uid != userId
          || (request.resource.data.active == true
            && request.resource.data.role == 'admin')))
        || (isActive()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastLoginAt', 'lastSeenAt', 'loginCount'])
          && request.resource.data.lastLoginAt == request.time
          && request.resource.data.lastSeenAt == request.time
          && request.resource.data.loginCount is int);

      allow delete: if false;
    }

    match /userInvites/{inviteId} {
      allow get: if isAdmin()
        || (resource.data.status == 'pending'
          && resource.data.expiresAt > request.time);
      allow list: if isAdmin();

      allow create: if isAdmin() && validInviteData(request.resource.data);

      allow update: if isAdmin()
        || (signedIn()
          && resource.data.status == 'pending'
          && resource.data.expiresAt > request.time
          && request.auth.token.email == resource.data.email
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedAt', 'acceptedUid'])
          && request.resource.data.status == 'accepted'
          && request.resource.data.acceptedUid == request.auth.uid
          && request.resource.data.acceptedAt == request.time);

      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAdmin()
        || isRequestParticipant(resource.data)
        || canViewProgramming(resource.data);

      allow create: if (isAdmin() && validRequestData(request.resource.data))
        || (isActive()
          && request.resource.data.requesterUid == request.auth.uid
          && request.resource.data.requesterEmail == request.auth.token.email
          && request.resource.data.status == 'nova'
          && emptyCancellationCrmOnCreate(request.resource.data)
          && validRequestData(request.resource.data));

      allow update: if isAdmin()
        && request.resource.data.type == resource.data.type
        && validRequestData(request.resource.data);

      allow update: if isRequestParticipant(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['commentCount', 'updatedAt', 'updatedByUid', 'updatedByName'])
        && commentCountIncremented()
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedAt == request.time;

      allow update: if isActive()
        && resource.data.requesterUid == request.auth.uid
        && resource.data.status == 'nova'
        && request.resource.data.status == 'nova'
        && request.resource.data.requesterUid == resource.data.requesterUid
        && request.resource.data.requesterEmail == resource.data.requesterEmail
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.type == resource.data.type
        && cancellationCrmUnchangedByRequester()
        && cancellationListCanChangeByRequester()
        && validRequestData(request.resource.data);

      allow delete: if isAdmin();
    }

    match /archivedRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && validRequestData(request.resource.data)
        && request.resource.data.archivedAt == request.time
        && request.resource.data.archivedByUid == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /requestComments/{commentId} {
      allow read: if canReadActiveRequest(resource.data.requestId)
        || canReadArchivedRequest(resource.data.requestId);

      allow create: if isActive()
        && validCommentData(request.resource.data)
        && canParticipateActiveRequest(request.resource.data.requestId);

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (isActive() && resource.data.targetUid == request.auth.uid);

      allow create: if validNotificationData(request.resource.data);

      allow update: if isActive()
        && resource.data.targetUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
        && request.resource.data.read == true
        && request.resource.data.readAt == request.time;

      allow delete: if isAdmin()
        || (isActive() && resource.data.targetUid == request.auth.uid);
    }

    match /requestHistory/{historyId} {
      allow read: if canReadActiveRequest(resource.data.requestId)
        || canReadArchivedRequest(resource.data.requestId);
      allow create: if isActive()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.requestId is string
        && request.resource.data.requestId.size() > 0
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0
        && request.resource.data.summary.size() <= 500
        && request.resource.data.action in ['create', 'update', 'status', 'comment', 'crm', 'archive', 'restore', 'bulk', 'attachment']
        && request.resource.data.createdAt == request.time
        && (canParticipateActiveRequest(request.resource.data.requestId)
          || canReadArchivedRequest(request.resource.data.requestId));
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /savedFilters/{filterId} {
      // O administrador pode ler todos os filtros para gerar o backup completo.
      // Os demais usuarios continuam acessando somente os proprios filtros.
      allow read: if isAdmin()
        || (isActive() && resource.data.ownerUid == request.auth.uid);
      allow create: if isActive()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.filters is map
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isActive() && resource.data.ownerUid == request.auth.uid;
    }

    match /commentTemplates/{templateId} {
      allow read: if isActive();
      allow create: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 800
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isAdmin();
    }

    match /accessLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isActive()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.eventType in ['login', 'logout', 'session_expired', 'password_changed', 'backup']
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /requestAttachments/{attachmentId} {
      allow read: if canReadActiveRequest(resource.data.requestId)
        || canReadArchivedRequest(resource.data.requestId);

      allow create: if validAttachmentData(request.resource.data)
        && (isAdmin()
          || (isActive() && request.resource.data.ownerUid == request.auth.uid));

      allow update: if false;

      allow delete: if isAdmin()
        || (isActive() && resource.data.ownerUid == request.auth.uid);
    }
  }
}
